# Shared local development configuration
NODE_ENV=development

# Backend
PORT=4000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
MAX_UPLOAD_MB=25
STORAGE_DIR=./data
UPLOAD_DIR=./uploads

# OpenAI
# Required for document indexing and grounded answer generation.
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
DEFAULT_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
MAX_CONTEXT_CHARS=12000
MIN_RELEVANCE_SCORE=0.15
VECTOR_PROVIDER=chroma

# Chroma local server
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_SSL=false
CHROMA_COLLECTION_NAME=rag_document_chunks

# Optional Pinecone support
PINECONE_API_KEY=
PINECONE_INDEX=
PINECONE_NAMESPACE=rag-document-qa

# Frontend
VITE_API_BASE_URL=http://localhost:4000
